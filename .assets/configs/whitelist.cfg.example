// WhiteList Configuration
// Auto-generated - edit values as needed

// Whitelist level: 0=disabled, 1=streamer, 2=+content, 3=+vip, 4=+whitelist
wl_level 0

// Broadcast a message in chat when a player is kicked
wl_broadcast_kick true

// Kick reason shown to the player
wl_kick_message "You are not whitelisted on this server"

// Broadcast message format ({0}=name, {1}=steamid)
wl_broadcast_message "{0} ({1}) has been kicked. Not whitelisted."
